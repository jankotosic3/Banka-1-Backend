# =========================
# Server / Docker Config
# =========================
API_GATEWAY_PORT=80
# Stari USER_SERVER_PORT — i dalje koristi employee-service do PR_02 C2.16 cleanup-a.
USER_SERVER_PORT=8081
# PR_02 C2.7: novi konsolidovani user-service port (zameni employee + client).
# Default 8081 = isti port kao stari employee-service da Nginx upstream ne mora menjati IP/port,
# samo ime kontejnera (vidi C2.15).
USER_SERVICE_PORT=8081
# DB connection vars za novi user-service (jedinstvena Postgres baza za employees + clients).
USER_SERVICE_DB_HOST=postgres
USER_SERVICE_DB_PORT=5432
USER_SERVICE_DB_NAME=user_service
USER_SERVICE_DB_USER=postgres
USER_SERVICE_DB_PASSWORD=postgres

# =========================
# Database Config (Postgres)
# =========================
# Single shared Postgres container
DB_HOST=postgres
DB_PORT=5432
DB_EX_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres

# Employee service DB
DB_NAME=banka

# Notification service DB
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=notification_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# =========================
# JWT refresh token TTL
# =========================
# Trajanje refresh tokena u DANIMA. PR_01 C1.7 smanjio default sa 1 mesec na 7 dana
# (banking-grade default; smanjuje window za stolen-refresh-token attack).
# Production override može biti i kraći (npr. 1 ili 3 dana) ako sigurnosni tim to zahteva.
TOKEN_REFRESH_EXPIRATION_DAYS=7

# =========================
# Swagger / OpenAPI
# =========================
# DEV default = true (Swagger UI dostupan na http://servis:port/swagger-ui/index.html
# i OpenAPI spec na /v3/api-docs).
# PRODUCTION: postaviti SWAGGER_ENABLED=false. Tada springdoc-openapi ne registruje endpointe
# i UI/spec rute vraćaju 404 čak i ako se neko probije pored gateway rate-limit-a.
# Postojeća .yml/.json dokumentacija u repository-ju (docs/openapi.yml u svakom servisu) ostaje
# valjana — koristi se u CI lint-u (redocly), ne na runtime-u.
SWAGGER_ENABLED=true

# =========================
# CORS (Cross-Origin Resource Sharing)
# =========================
# Allowed origins: comma-separated list (Spring Boot relaxed binding turns this into List<String>).
# DEV default = http://localhost:4200 (Angular dev server).
# PRODUCTION example: BANKA_SECURITY_CORS_ALLOWED_ORIGINS=https://banka1.example.com,https://app.banka1.example.com
BANKA_SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:4200
# Allowed HTTP verbs — eksplicitan whitelist umesto "*".
BANKA_SECURITY_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# Allowed request headers — eksplicitan whitelist umesto "*".
BANKA_SECURITY_CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept,X-Requested-With,X-Verification-Code,X-Correlation-Id
# Headers koji su izloženi browseru (read-only za frontend JS).
BANKA_SECURITY_CORS_EXPOSED_HEADERS=Location,X-Correlation-Id
# Cookie/auth credentials u CORS preflight-u.
BANKA_SECURITY_CORS_ALLOW_CREDENTIALS=true
# Cache za preflight (sekunde).
BANKA_SECURITY_CORS_MAX_AGE_SECONDS=3600

# =========================
# JMBG enkripcija (PR_07 + PR_29 fail-fast)
# =========================
# AES-256 kljuc za enkripciju JMBG kolone (32 bajta = 256 bita, Base64 kodiran).
# Generisi sa: openssl rand -base64 32
# DEV default ispod radi samo u dev/local/test profilu — u prod profilu (npr.
# SPRING_PROFILES_ACTIVE=prod) servis FAIL-uje pri startup-u ako je ovaj env var
# nepostavljen ili sadrzi javni dev kljuc. Ovo sprecava silent enkripciju JMBG-ova
# javno poznatim dev kljucem.
BANKA_SECURITY_JMBG_AES_KEY=VGhpc0lzQURldk9ubHkzMkJ5dGVBRVNLZXktMTIzNDU=

# =========================
# Margin transfer racuni (PR_12 + PR_29 fail-fast)
# =========================
# Spec: Marzni_Racuni.txt — buy/sell margin transakcija ide preko racuna banke i
# berze. Ovi racuni MORAJU postojati u accounts tabeli i biti aktivni; u suprotnom
# stockBuyMarginTransaction silent fail-uje (debit nepostojeceg racuna).
# DEV default-ovi su iz seed migracija. PROD profil zahteva eksplicitno postavljanje
# za sve cetiri vrednosti (BankToExchangeTransferService validira na startup-u).
BANKA_BANKING_BANK_ACCOUNT_NUMBER=111000110000000312
BANKA_BANKING_EXCHANGE_ACCOUNT_NUMBER=111000300000002012
BANKA_BANKING_BANK_CLIENT_ID=-1
BANKA_BANKING_EXCHANGE_CLIENT_ID=-3

# =========================
# Loan interest rate parameters (PR_29 ConfigurationProperties)
# =========================
# Spec: Celina 2 — kamatna stopa zavisi od iznosa kredita (tier sistem) i moze biti
# fiksna ili varijabilna. Pre PR_29 ovi parametri su bili magic number-i u
# LoanServiceImplementation; sada su konfigurabilni preko banka.loan.interest-rate.*
# property-ja.
# Default-ovi odgovaraju ponasanju pre PR_29 — uncomment i postavi za override.
# BANKA_LOAN_INTEREST_RATE_BASE_ANNUAL_RATE_PERCENT=6.25
# BANKA_LOAN_INTEREST_RATE_STEP_PER_TIER_PERCENT=0.25
# BANKA_LOAN_INTEREST_RATE_OVERDUE_INCREMENT_PERCENT=0.05
# BANKA_LOAN_INTEREST_RATE_REFERENCE_RANDOM_MIN=-1.5
# BANKA_LOAN_INTEREST_RATE_REFERENCE_RANDOM_MAX=1.5
# BANKA_LOAN_INTEREST_RATE_MONTHLY_DIVISOR=1200
# Spring relaxed binding za List<BigDecimal>: comma-separated value.
# BANKA_LOAN_INTEREST_RATE_AMOUNT_TIERS=500000,1000000,2000000,5000000,10000000,20000000

# =========================
# Liquibase contexts
# =========================
# Default "dev" includes test users (admin@banka.com / admin123, client@banka.com / client123,
# Mateja Subin, 8 test client accounts + sample orders) so that local docker-compose and Cypress
# E2E specs work out of the box.
# PRODUCTION deploys MUST override this to a context that does NOT include "dev", e.g. "prod".
# All changesets marked context:dev are then skipped — only the production-grade changesets
# (currencies, Banka1 = Firma, Naša država = Firma) are applied.
LIQUIBASE_CONTEXTS=dev

