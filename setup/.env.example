# =========================
# Firebase Config
# =========================
# Firebase Cloud Messaging (FCM)
# =========================
# Absolute path on the host where the Firebase service-account JSON lives.
# The file MUST be outside the repository working tree (never commit it).
# When the operator does not need FCM push, leave this unset and FCM is gracefully disabled.
# Example (local dev): FIREBASE_CREDENTIALS_HOST_PATH=/Users/me/secrets/banka1-firebase.json
FIREBASE_CREDENTIALS_HOST_PATH=

# Path inside the notification-service container where the JSON is mounted.
# Defaults to /app/firebase-credentials.json. Override only if the application code expects another path.
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# =========================
# Spring profiles (multi-service activation)
# =========================
# DO NOT setovati ovde — `mock-partner` profil je samo za interbank-service, a aktivacija
# `dev` profila globalno breakuje trading-service (pre-existing typo u order-service
# application-dev.properties referencira nepostojeci `db.changelog-dev.xml`).
# Per-service `SPRING_PROFILES_ACTIVE` je vec eksplicitno setovan u
# docker-compose.yml za interbank-service block. Ako trebas debug, set u shell:
#   $env:SPRING_PROFILES_ACTIVE = "dev,mock-partner" (PowerShell)
#   export SPRING_PROFILES_ACTIVE=dev,mock-partner (bash)
# pre `docker compose up`, NE u .env globalno.
# SPRING_PROFILES_ACTIVE=dev,mock-partner   # DISABLED — vidi gore

